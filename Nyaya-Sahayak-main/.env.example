# Copy this file to .env and fill in your values

# Required for embeddings and LLM
GROQ_API_KEY=your_groq_api_key_here
# Optional alternative provider (if you use Gemini instead of Groq)
# GOOGLE_API_KEY=your_google_api_key_here
# Optional: model overrides
# GROQ_MODEL=llama3-8b-8192
# GEMINI_MODEL=gemini-1.5-flash
# Optional: path to BNS PDF file OR folder containing multiple BNS PDFs
# Default: data/raw (folder - all *.pdf inside are loaded)
# BNS_PDF_PATH=C:\path\to\BNS.pdf
# BNS_PDF_PATH=C:\path\to\bns_folder
